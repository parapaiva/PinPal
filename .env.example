# PinPal — environment variables
# Copy to .env and adjust as needed. Defaults match docker-compose.yml.

# --- Postgres ---
PINPAL_POSTGRES_HOST=localhost
PINPAL_POSTGRES_PORT=5432
PINPAL_POSTGRES_USER=pinpal
PINPAL_POSTGRES_PASSWORD=pinpal
PINPAL_POSTGRES_DB=pinpal

# --- MongoDB ---
PINPAL_MONGO_HOST=localhost
PINPAL_MONGO_PORT=27017
PINPAL_MONGO_USER=pinpal
PINPAL_MONGO_PASSWORD=pinpal
PINPAL_MONGO_DB=pinpal

# --- App ---
PINPAL_LOG_LEVEL=INFO
PINPAL_LOG_FORMAT=json
